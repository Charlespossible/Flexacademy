// FlexAcademy — Prisma Schema
// DB: PostgreSQL | ORM: Prisma v5

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  STUDENT
  TUTOR
  ADMIN
  SUPER_ADMIN
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum ContentType {
  VIDEO
  TEXT
  QUIZ
  FLASHCARD
  PAST_QUESTION
  LIVE_CLASS
  DOCUMENT
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXAM_READY
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  ESSAY
  FILL_IN_BLANK
  DRAG_AND_DROP
}

enum ExamCategory {
  WAEC
  JAMB
  NECO
  GCE
  COMMON_ENTRANCE
  IGCSE
  SAT
  IELTS
  GMAT
  GRE
  CUSTOM
}

enum SessionStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum NotificationType {
  STUDY_REMINDER
  BADGE_EARNED
  STREAK_MILESTONE
  EXAM_REMINDER
  NEW_CONTENT
  RESULT_READY
  LEADERBOARD_UPDATE
  SYSTEM
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  phone             String?          @unique
  passwordHash      String?
  firstName         String
  lastName          String
  avatar            String?
  role              Role             @default(STUDENT)
  isEmailVerified   Boolean          @default(false)
  isPhoneVerified   Boolean          @default(false)
  isActive          Boolean          @default(true)
  googleId          String?          @unique
  refreshTokenHash  String?
  lastLoginAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Relations
  studentProfile    StudentProfile?
  tutorProfile      TutorProfile?
  subscription      Subscription?
  enrollments       Enrollment[]
  quizAttempts      QuizAttempt[]
  studySessions     StudySession[]
  notifications     Notification[]
  payments          Payment[]
  badges            UserBadge[]
  progressRecords   LearningProgress[]
  leaderboardEntries LeaderboardEntry[]
  aiSessions        AiTutorSession[]
  liveClassBookings LiveClassBooking[]
  parentLinks       ParentStudentLink[] @relation("ParentUser")
  childLinks        ParentStudentLink[] @relation("ChildUser")
  auditLogs         AuditLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model StudentProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  gradeLevel      String    // e.g. "SS3", "JSS2", "Primary 6"
  curriculum      String    // e.g. "WAEC", "IGCSE", "Cambridge"
  school          String?
  state           String?
  country         String    @default("Nigeria")
  studyGoal       String?
  targetExams     ExamCategory[]
  targetYear      Int?
  studyStreakDays  Int       @default(0)
  totalXp         Int       @default(0)
  weeklyGoalMins  Int       @default(120)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model TutorProfile {
  id                String    @id @default(uuid())
  userId            String    @unique
  bio               String?
  qualifications    String[]
  specializations   String[]
  yearsOfExperience Int       @default(0)
  hourlyRate        Decimal?  @db.Decimal(10, 2)
  rating            Decimal   @default(0) @db.Decimal(3, 2)
  totalReviews      Int       @default(0)
  isVerified        Boolean   @default(false)
  availabilitySlots Json?     // JSON schedule
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveClasses       LiveClass[]

  @@map("tutor_profiles")
}

model ParentStudentLink {
  id        String   @id @default(uuid())
  parentId  String
  studentId String
  createdAt DateTime @default(now())

  parent    User     @relation("ParentUser", fields: [parentId], references: [id])
  child     User     @relation("ChildUser", fields: [studentId], references: [id])

  @@unique([parentId, studentId])
  @@map("parent_student_links")
}

// ─────────────────────────────────────────────
// SUBSCRIPTIONS & PAYMENTS
// ─────────────────────────────────────────────

model Subscription {
  id                String             @id @default(uuid())
  userId            String             @unique
  tier              SubscriptionTier   @default(FREE)
  status            SubscriptionStatus @default(TRIAL)
  stripeCustomerId  String?
  stripeSubId       String?
  currentPeriodStart DateTime?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean            @default(false)
  trialEndsAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments          Payment[]

  @@map("subscriptions")
}

model Payment {
  id               String        @id @default(uuid())
  userId           String
  subscriptionId   String?
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("NGN")
  status           PaymentStatus @default(PENDING)
  provider         String        // "stripe" | "paystack" | "flutterwave"
  providerRef      String?       @unique
  metadata         Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user             User          @relation(fields: [userId], references: [id])
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("payments")
}

// ─────────────────────────────────────────────
// CURRICULUM & CONTENT
// ─────────────────────────────────────────────

model Subject {
  id          String    @id @default(uuid())
  name        String    @unique // "Mathematics", "English", "Physics"
  slug        String    @unique
  description String?
  icon        String?
  color       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  topics      Topic[]
  courses     Course[]

  @@map("subjects")
}

model Topic {
  id          String    @id @default(uuid())
  subjectId   String
  name        String
  slug        String
  description String?
  order       Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  subject     Subject   @relation(fields: [subjectId], references: [id])
  lessons     Lesson[]
  questions   Question[]

  @@unique([subjectId, slug])
  @@index([subjectId])
  @@map("topics")
}

model Course {
  id              String          @id @default(uuid())
  subjectId       String
  title           String
  slug            String          @unique
  description     String?
  thumbnail       String?
  difficulty      DifficultyLevel @default(BEGINNER)
  gradeLevel      String?
  curriculum      String?
  isFree          Boolean         @default(false)
  requiredTier    SubscriptionTier @default(FREE)
  totalDuration   Int             @default(0) // minutes
  isPublished     Boolean         @default(false)
  publishedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  subject         Subject         @relation(fields: [subjectId], references: [id])
  lessons         Lesson[]
  enrollments     Enrollment[]
  progressRecords LearningProgress[]

  @@index([subjectId])
  @@index([isPublished])
  @@map("courses")
}

model Lesson {
  id           String      @id @default(uuid())
  courseId     String
  topicId      String?
  title        String
  slug         String
  contentType  ContentType
  content      String?     // markdown text or URL
  videoUrl     String?
  duration     Int?        // minutes
  order        Int         @default(0)
  isFree       Boolean     @default(false)
  isPublished  Boolean     @default(false)
  aiSummary    String?     // AI-generated lesson summary
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  course       Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  topic        Topic?      @relation(fields: [topicId], references: [id])
  studySessions StudySession[]

  @@unique([courseId, slug])
  @@index([courseId])
  @@map("lessons")
}

// ─────────────────────────────────────────────
// EXAM QUESTIONS & QUIZZES
// ─────────────────────────────────────────────

model Question {
  id              String        @id @default(uuid())
  topicId         String?
  subjectId       String?
  examCategory    ExamCategory?
  year            Int?          // Exam year (for past questions)
  questionType    QuestionType  @default(MULTIPLE_CHOICE)
  body            String        // The question text (supports Markdown + LaTeX)
  imageUrl        String?
  options         Json?         // [{id, text, isCorrect}]
  correctAnswer   String?
  explanation     String?       // Detailed solution explanation
  difficulty      DifficultyLevel @default(INTERMEDIATE)
  marks           Int           @default(1)
  aiGenerated     Boolean       @default(false)
  tags            String[]
  isVerified      Boolean       @default(false)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  topic           Topic?        @relation(fields: [topicId], references: [id])
  quizQuestions   QuizQuestion[]
  attemptAnswers  AttemptAnswer[]

  @@index([examCategory, year])
  @@index([topicId])
  @@map("questions")
}

model Quiz {
  id              String          @id @default(uuid())
  title           String
  description     String?
  examCategory    ExamCategory?
  subjectId       String?
  gradeLevel      String?
  difficulty      DifficultyLevel @default(INTERMEDIATE)
  timeLimit       Int?            // minutes
  passMark        Int             @default(50) // percentage
  shuffleQuestions Boolean        @default(true)
  shuffleOptions  Boolean         @default(true)
  isPublished     Boolean         @default(false)
  requiredTier    SubscriptionTier @default(FREE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  questions       QuizQuestion[]
  attempts        QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id         String   @id @default(uuid())
  quizId     String
  questionId String
  order      Int      @default(0)

  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id])

  @@unique([quizId, questionId])
  @@map("quiz_questions")
}

model QuizAttempt {
  id           String    @id @default(uuid())
  userId       String
  quizId       String
  score        Int       @default(0)
  totalMarks   Int       @default(0)
  percentage   Decimal   @db.Decimal(5, 2) @default(0)
  timeTaken    Int?      // seconds
  isPassed     Boolean   @default(false)
  completedAt  DateTime?
  aiAnalysis   String?   // AI-generated performance feedback
  startedAt    DateTime  @default(now())
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id])
  quiz         Quiz      @relation(fields: [quizId], references: [id])
  answers      AttemptAnswer[]

  @@index([userId])
  @@index([quizId])
  @@map("quiz_attempts")
}

model AttemptAnswer {
  id             String      @id @default(uuid())
  attemptId      String
  questionId     String
  selectedOption String?
  writtenAnswer  String?
  isCorrect      Boolean     @default(false)
  marksAwarded   Int         @default(0)
  timeTaken      Int?        // seconds per question
  createdAt      DateTime    @default(now())

  attempt        QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question    @relation(fields: [questionId], references: [id])

  @@unique([attemptId, questionId])
  @@map("attempt_answers")
}

// ─────────────────────────────────────────────
// LEARNING PROGRESS & GAMIFICATION
// ─────────────────────────────────────────────

model Enrollment {
  id           String    @id @default(uuid())
  userId       String
  courseId     String
  enrolledAt   DateTime  @default(now())
  completedAt  DateTime?
  isCompleted  Boolean   @default(false)

  user         User      @relation(fields: [userId], references: [id])
  course       Course    @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("enrollments")
}

model LearningProgress {
  id              String    @id @default(uuid())
  userId          String
  courseId        String
  completedLessons String[] // lesson IDs
  progressPercent Decimal   @db.Decimal(5, 2) @default(0)
  lastAccessedAt  DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id])
  course          Course    @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
  @@map("learning_progress")
}

model StudySession {
  id         String   @id @default(uuid())
  userId     String
  lessonId   String?
  subject    String?
  durationMins Int    @default(0)
  xpEarned   Int      @default(0)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  lesson     Lesson?  @relation(fields: [lessonId], references: [id])

  @@index([userId])
  @@map("study_sessions")
}

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  description String
  icon        String
  criteria    Json        // {type: "streak", value: 7}
  xpReward    Int         @default(0)
  createdAt   DateTime    @default(now())

  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id])

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model LeaderboardEntry {
  id        String   @id @default(uuid())
  userId    String
  period    String   // "daily", "weekly", "monthly", "all-time"
  subject   String?
  score     Int      @default(0)
  rank      Int?
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, period, subject])
  @@index([period, score])
  @@map("leaderboard_entries")
}

// ─────────────────────────────────────────────
// AI TUTOR
// ─────────────────────────────────────────────

model AiTutorSession {
  id          String   @id @default(uuid())
  userId      String
  subject     String?
  topic       String?
  messages    Json     // [{role, content, timestamp}]
  tokensUsed  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("ai_tutor_sessions")
}

// ─────────────────────────────────────────────
// LIVE CLASSES
// ─────────────────────────────────────────────

model LiveClass {
  id              String        @id @default(uuid())
  tutorProfileId  String
  title           String
  description     String?
  subject         String
  gradeLevel      String?
  scheduledAt     DateTime
  durationMins    Int           @default(60)
  maxStudents     Int           @default(50)
  status          SessionStatus @default(SCHEDULED)
  meetingUrl      String?
  recordingUrl    String?
  requiredTier    SubscriptionTier @default(PRO)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tutor           TutorProfile  @relation(fields: [tutorProfileId], references: [id])
  bookings        LiveClassBooking[]

  @@index([scheduledAt])
  @@map("live_classes")
}

model LiveClassBooking {
  id           String    @id @default(uuid())
  userId       String
  liveClassId  String
  bookedAt     DateTime  @default(now())
  attended     Boolean   @default(false)

  user         User      @relation(fields: [userId], references: [id])
  liveClass    LiveClass @relation(fields: [liveClassId], references: [id])

  @@unique([userId, liveClassId])
  @@map("live_class_bookings")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS & AUDIT
// ─────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}
