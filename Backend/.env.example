# ─────────────────────────────────────────────
# FlexAcademy — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000
APP_NAME=FlexAcademy
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
API_VERSION=v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/flexacademy_dev
DATABASE_SHADOW_URL=postgresql://postgres:password@localhost:5432/flexacademy_shadow

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@flexacademy.com
FROM_NAME=FlexAcademy

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Paystack (Nigeria)
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_

# AI — Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# AI — OpenAI (fallback / embeddings)
OPENAI_API_KEY=sk-
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Cloudinary (Media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Feature Flags
ENABLE_AI_TUTOR=true
ENABLE_LIVE_CLASSES=true
ENABLE_LEADERBOARD=true
